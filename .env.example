# Schwab OAuth — get these at https://developer.schwab.com
# When set, the dashboard fetches real chain data from Schwab.
# When unset, the dashboard runs in demo mode with synthetic data.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# OAuth callback URL. Must match what you registered with Schwab.
# Local:    http://localhost:3000/api/auth/callback
# Vercel:   https://<your-project>.vercel.app/api/auth/callback
SCHWAB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Vercel KV — auto-populated by Vercel when you attach a KV store.
# For local dev: `vercel env pull .env.local` after linking the project.
# Only required in live mode.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
